# -----------------------------------------------------------------------------
# NextAuth: https://shipfa.st/docs/tutorials/user-auth
# -----------------------------------------------------------------------------
# NEXTAUTH_URL is optional in local dev. If you need auth callbacks from another
# device, set it temporarily in your shell to that device-reachable origin.
# NEXTAUTH_URL=http://<your-lan-ip>:3000
NEXTAUTH_SECRET=uhf3874y7fh387uch3fiuh347u4rh9394hf

# -----------------------------------------------------------------------------
# Google OAuth: https://shipfa.st/docs/features/google-oauth
# -----------------------------------------------------------------------------
GOOGLE_ID=
GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_AUTH_FROM="Legal Arena <noreply@legalarena.app>"

# -----------------------------------------------------------------------------
# OpenAI
# Optional: use a faster model for unattended case-template rebalance jobs
# -----------------------------------------------------------------------------
OPENAI_MODEL=
OPENAI_GENERATION_MODEL=
OPENAI_DYNAMIC_CASE_MODEL=gpt-5.4-mini
OPENAI_REBALANCE_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_PORTRAIT_IMAGE_MODEL=gpt-image-2
OPENAI_PORTRAIT_IMAGE_QUALITY=low

# -----------------------------------------------------------------------------
# Vercel Blob
# Stores generated 500x500 lawyer headshots after OpenAI transforms the upload.
# Private stores are supported; the app serves avatars through /api/players/avatar/[playerId].
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# DataFast
# Browser analytics and server-side bot traffic tracking
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=dfid_jj19izF8dJN5YpCrXoA2G

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# Legal Arena access gating
# Comma-separated list or JSON array of emails allowed to play for free
# Example: ACCESS_GRANTED=alice@example.com,bob@example.com
# -----------------------------------------------------------------------------
ACCESS_GRANTED=

# AI-player API credential throttling (per key)
AI_API_RATE_LIMIT=60
AI_API_RATE_LIMIT_WINDOW_SECONDS=300

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Lemon Squeezy
# -----------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_VARIANT_ID_DEV=
LEMONSQUEEZY_SIGNING_SECRET=
