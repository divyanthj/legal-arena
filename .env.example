NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=uhf3874y7fh387uch3fiuh347u4rh9394hf

# -----------------------------------------------------------------------------
# Google OAuth: https://shipfa.st/docs/features/google-oauth
# -----------------------------------------------------------------------------
GOOGLE_ID=
GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_AUTH_FROM="Legal Arena <noreply@legalarena.app>"

# -----------------------------------------------------------------------------
# OpenAI
# Optional: use a faster model for unattended case-template rebalance jobs
# -----------------------------------------------------------------------------
OPENAI_MODEL=
OPENAI_GENERATION_MODEL=
OPENAI_REBALANCE_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-1.5

# -----------------------------------------------------------------------------
# Vercel Blob
# Stores generated 500x500 lawyer headshots after OpenAI transforms the upload.
# Private stores are supported; the app serves avatars through /api/players/avatar/[playerId].
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# Legal Arena access gating
# Comma-separated list or JSON array of emails allowed to play for free
# Example: ACCESS_GRANTED=alice@example.com,bob@example.com
# -----------------------------------------------------------------------------
ACCESS_GRANTED=

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Lemon Squeezy
